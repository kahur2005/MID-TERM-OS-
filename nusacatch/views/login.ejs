<%- include('partials/header', { title: 'Login — NusaCatch' }) %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="auth-logo">🐟</span>
      <h1>NusaCatch</h1>
      <p>The ultimate fishing competition</p>
    </div>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form action="/auth/login" method="POST" class="auth-form">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@email.com" required/>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required/>
      </div>
      <button type="submit" class="btn-primary btn-full">Login</button>
    </form>
    <p class="auth-switch">No account? <a href="/auth/register">Register here</a></p>
  </div>
  <div class="auth-visual">
    <div class="wave-text">Cast your line.<br/>Claim the throne.</div>
    <div class="ocean-anim">🌊</div>
  </div>
</div>
<%- include('partials/footer') %>
