<%- include('partials/header', { title: 'Dashboard — NusaCatch' }) %>
<%- include('partials/navbar') %>

<main class="main-content">
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

  <section class="welcome-banner">
    <div class="welcome-text">
      <h2>Welcome back, <span class="accent"><%= user.username %></span> 🎣</h2>
      <p>Submit your catch and climb the leaderboard!</p>
    </div>
    <% if (personalBest) { %>
      <div class="personal-best">
        <span class="pb-label">Your Personal Best</span>
        <span class="pb-value"><%= personalBest.size_inches %>"</span>
        <span class="pb-fish"><%= personalBest.fish_name %></span>
      </div>
    <% } %>
  </section>

  <div class="dashboard-grid">
    <!-- Submit Catch -->
    <section class="card submit-card">
      <h3 class="card-title">🐠 Submit a Catch</h3>
      <form action="/catch/submit" method="POST" enctype="multipart/form-data" class="catch-form">
        <div class="form-row">
          <div class="form-group">
            <label for="fish_name">Fish Name *</label>
            <input type="text" id="fish_name" name="fish_name" placeholder="e.g. Tuna" required maxlength="100"/>
          </div>
          <div class="form-group">
            <label for="size_inches">Size (inches) *</label>
            <input type="number" id="size_inches" name="size_inches" placeholder="e.g. 42.5" step="0.1" min="1" max="300" required/>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="weight_lbs">Weight (lbs)</label>
            <input type="number" id="weight_lbs" name="weight_lbs" placeholder="e.g. 12.3" step="0.1" min="0"/>
          </div>
          <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" placeholder="e.g. Lombok, NTB" maxlength="150"/>
          </div>
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" placeholder="Tell the story..." rows="2" maxlength="500"></textarea>
        </div>
        <div class="form-group">
          <label for="fish_image">Fish Photo * <small>(jpg/png, max 5MB)</small></label>
          <div class="file-upload-wrapper">
            <input type="file" id="fish_image" name="fish_image" accept=".jpg,.jpeg,.png,.webp" required/>
            <label for="fish_image" class="file-upload-label">📷 Choose Photo</label>
            <span class="file-name" id="file-name-display">No file chosen</span>
          </div>
        </div>
        <button type="submit" class="btn-primary">Submit Catch 🎣</button>
      </form>
    </section>

    <!-- Leaderboard Preview -->
    <section class="card leaderboard-card">
      <div class="card-header-row">
        <h3 class="card-title">🏆 Top 10</h3>
        <a href="/leaderboard" class="btn-secondary">View All</a>
      </div>
      <% if (leaderboard.length === 0) { %>
        <p class="empty-state">No catches yet. Be the first!</p>
      <% } else { %>
        <table class="leaderboard-table">
          <thead><tr><th>#</th><th>Angler</th><th>Fish</th><th>Size</th></tr></thead>
          <tbody>
            <% leaderboard.forEach(e => { %>
              <tr class="<%= e.rank <= 3 ? 'top-rank' : '' %>">
                <td class="rank-cell">
                  <% if (e.rank == 1) { %>🥇<% } else if (e.rank == 2) { %>🥈<% } else if (e.rank == 3) { %>🥉<% } else { %>#<%= e.rank %><% } %>
                </td>
                <td><strong><%= e.username %></strong></td>
                <td><%= e.fish_name %></td>
                <td class="size-cell"><%= e.size_inches %>"</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>
  </div>

  <!-- My Catches -->
  <section class="card my-catches-card">
    <h3 class="card-title">🗂️ My Catches (<%= myCatches.length %>)</h3>
    <% if (myCatches.length === 0) { %>
      <p class="empty-state">No catches yet. Get fishing!</p>
    <% } else { %>
      <div class="catches-grid">
        <% myCatches.forEach(c => { %>
          <div class="catch-item">
            <img src="<%= c.image_path %>" alt="<%= c.fish_name %>" class="catch-img" loading="lazy"/>
            <div class="catch-info">
              <h4><%= c.fish_name %></h4>
              <p class="catch-size"><%= c.size_inches %>"<% if (c.weight_lbs) { %> &bull; <%= c.weight_lbs %> lbs<% } %></p>
              <% if (c.location)    { %><p class="catch-location">📍 <%= c.location %></p><% } %>
              <% if (c.description) { %><p class="catch-desc"><%= c.description %></p><% } %>
              <p class="catch-date"><%= new Date(c.submitted_at).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) %></p>
            </div>
            <form action="/catch/delete/<%= c.id %>" method="POST" onsubmit="return confirm('Delete this catch?')">
              <button type="submit" class="btn-delete" title="Delete">🗑️</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include('partials/footer') %>
